# PostgreSQL session/direct connection used by local development, migrations, and CI.
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@SESSION_POOLER_HOST:5432/postgres"

# PostgreSQL transaction pooler used by local scripts that need direct SQL.
DATABASE_URL="postgresql://USER:PASSWORD@TRANSACTION_POOLER_HOST:6543/postgres"

# Supabase HTTP API used by the Cloudflare Worker runtime for v0.
SUPABASE_URL="https://PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""
SUPABASE_JWKS_URL="https://PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json"

OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="tencent/hy3"

# Slice 3 cited recall embeddings. Uses the same OpenRouter API key.
EMBEDDING_PROVIDER="openrouter"
EMBEDDING_BASE_URL="https://openrouter.ai/api/v1"
EMBEDDING_MODEL="qwen/qwen3-embedding-8b"
EMBEDDING_DIMENSIONS="1536"
EMBEDDING_ENCODING_FORMAT="float"

# v0 shared webapp gate. Keep server-side only; do not expose through NEXT_PUBLIC_*.
DISTILLERY_APP_PASSWORD=""
