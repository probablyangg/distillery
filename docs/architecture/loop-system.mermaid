flowchart TB

%% DISTILLERY LOOP SYSTEM
%% Status: simplified current architecture through migration 0021.
%% PostgreSQL is canonical. Cloudflare Queue carries only workItemId wakeups.

subgraph INPUTS["Committed inputs"]
  direction TB
  I1["Direct text capture<br/>source_committed"]
  I2["Slack shortcut<br/>durable connector save"]
  I3["Human memory review<br/>confirmed, edited, removed"]
  I4["Human synthesis action<br/>manual synthesis_ready intent"]
end

subgraph LEDGER["Canonical PostgreSQL loop state"]
  direction TB
  L1["ledger_events"]
  L2["event_outbox"]
  L3["pending_work<br/>lease + fencing token"]
  L4["policy_runs"]
  L5["proposed_events"]
end

subgraph TRANSPORT["Noncanonical transport and recovery"]
  direction TB
  Q["Cloudflare Queue<br/>{ workItemId }"]
  C["Cron every minute<br/>recover, requeue, scan, route"]
end

subgraph EXECUTOR["Worker executor"]
  direction TB
  E1["Claim pending_work"]
  E2["Load typed canonical input"]
  E3["Run one policy"]
  E4["Validate output"]
  E5{"Human review required?"}
  E6["Atomic auto-approved commit"]
  E7["Wait for approve/reject"]
end

subgraph CAPTURE["Evidence to memory"]
  direction TB
  P0["ingest_slack_source<br/>context refresh + immutable bundle"]
  P1["extract_slack_context"]
  P2["extract_memory<br/>choose single or sectioned path"]
  P3["extract_memory_section<br/>independent checkpoint"]
  P4["consolidate_memory<br/>after all sections complete"]
  M["memory_committed"]
  R["sync_slack_reaction<br/>after current context extraction"]
end

subgraph ENRICH["Post-memory enrichment"]
  direction TB
  P5["connect_memory"]
  P6["detect_contradiction"]
  P7["update_embeddings"]
  P8["update_graph"]
  X["connections / contradictions /<br/>embeddings / graph updated"]
end

subgraph SYNTH["Corpus synthesis"]
  direction TB
  P9["recompute_cluster"]
  S1["versioned overlapping clusters"]
  P10["evaluate_synthesis_readiness"]
  S2["pending_enrichment | not_ready | synthesis_ready"]
  P11["synthesize_brief"]
  S3["traceable suggested brief draft"]
end

subgraph PLACEHOLDERS["Installed placeholders"]
  direction TB
  H1["discover_candidate"]
  H2["check_freshness"]
  H3["rank_candidate"]
  H4["draft_artifact"]
  H5["gate_output"]
  H6["revise_artifact"]
end

I1 --> L1
I2 --> L3
I3 --> L1
I4 --> L1
L1 --> L2
L2 --> L3
L3 --> Q
Q --> E1
C --> L2
C --> L3
C --> Q
E1 --> E2
E2 --> E3
E3 --> L4
E3 --> E4
E4 --> L5
L5 --> E5
E5 -->|"No"| E6
E5 -->|"Yes"| E7
E7 -->|"Approve"| E6
E7 -->|"Reject"| L5
E6 --> L1

I2 --> P0
P0 --> L1
L1 --> P1
I1 --> P2
P2 --> P3
P3 --> P4
P2 --> M
P4 --> M
P1 --> M
P1 --> R

M --> P5
M --> P6
M --> P7
M --> P8
P5 --> X
P6 --> X
P7 --> X
P8 --> X
M --> P9
X --> P9
I3 --> P9
P9 --> S1
S1 --> P10
P10 --> S2
S2 -->|"synthesis_ready"| P11
P11 --> S3

M -.-> H1
M -.-> H2
H1 -.-> H3
H3 -.-> H4
H4 -.-> H5
H5 -.-> H6
