%% DISTILLERY V0 CURRENT SYSTEM
%% Status: implemented private pilot.

subgraph USER["Human user"]
  A["/ capture + recall<br/>one text input"]
  B["/synthesis<br/>reviewer surface"]
end

subgraph WORKER["Cloudflare Worker"]
  C["Shared-password session"]
  D["Ingestion API"]
  E["Recall API"]
  F["Synthesis / brief APIs"]
  G["Queue consumer"]
end

subgraph MODEL["OpenRouter"]
  H["Memory generation model"]
  I["Brief draft model"]
end

subgraph DB["Supabase PostgreSQL"]
  J["Source versions + evidence spans"]
  K["Memory items<br/>claimType, entities, relations, schemas"]
  L["Memory item events<br/>confirm, edit, remove"]
  M["Initiative briefs"]
  N["Brief evidence bindings"]
  O["Brief decisions<br/>approve / reject"]
end

