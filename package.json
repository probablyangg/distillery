{
  "name": "distillery",
  "version": "0.0.0",
  "private": true,
  "description": "Evidence-backed company memory and initiative synthesis.",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm typecheck && pnpm test && pnpm fixtures:validate && pnpm retrieval:validate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "fixtures:validate": "tsx evals/runners/validate-memory-fixtures.ts",
    "retrieval:validate": "tsx evals/runners/validate-retrieval-fixtures.ts",
    "retrieval:migrate": "tsx scripts/apply-latest-migration.ts packages/db/migrations/0011_hybrid_retrieval_rpcs.sql",
    "retrieval:backfill": "tsx scripts/backfill-memory-embeddings.ts",
    "smoke:live": "tsx evals/runners/live-v0-smoke.ts",
    "slack:verify": "tsx scripts/verify-slack-pilot.ts",
    "slack:test-signed": "tsx scripts/send-signed-slack-shortcut.ts",
    "slack:verify-save": "tsx scripts/verify-live-slack-save.ts",
    "slack:recover-one": "tsx scripts/recover-live-work-item.ts",
    "pilot:verify-schema": "tsx scripts/verify-pilot-schema.ts",
    "test:slack-db": "tsx scripts/test-slack-database.ts",
    "smoke:deployed": "tsx scripts/verify-deployed-briefs.ts",
    "reset:stable": "tsx scripts/reset-stable-data.ts",
    "seed:stable": "tsx scripts/seed-stable-memory.ts",
    "dev": "wrangler dev --config apps/web/wrangler.toml",
    "deploy": "wrangler deploy --config apps/web/wrangler.toml",
    "deploy:cloudflare": "tsx scripts/deploy-cloudflare.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260706.1",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
